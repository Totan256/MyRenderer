#version 450

// 1グループあたりのスレッド数 (16x16 = 256スレッド)
layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

// ピクセルごとの色情報 (RGBA)
struct Pixel {
    float r, g, b, a;
};

// 出力用バッファ (Binding = 0)
layout(std140, binding = 0) buffer PixelBuffer {
    Pixel pixels[];
} image;

void main() {
    // 現在の画素位置 (x, y)
    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;

    // 画像サイズ (とりあえずハードコード。後で定数バッファなどで渡すようにします)
    uint width = 800;
    uint height = 600;

    // 範囲外なら何もしない
    if (x >= width || y >= height) return;

    // 1次元配列のインデックスを計算
    uint index = y * width + x;

    // UV座標 (0.0 ~ 1.0) の計算
    float u = float(x) / float(width);
    float v = float(y) / float(height);

    // 色の計算: 綺麗なグラデーション
    image.pixels[index].r = u;          // X軸: 赤が増える
    image.pixels[index].g = v;          // Y軸: 緑が増える
    image.pixels[index].b = 0.2;        // 青は固定
    image.pixels[index].a = 1.0;        // アルファは不透明
}