#version 450
layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

struct Pixel {
    float r, g, b, a;
};

// Binding 0: 書き込み用画像データ (Storage Buffer)
layout(std140, binding = 0) buffer PixelBuffer {
    Pixel pixels[];
} image;

// Binding 1: 読み取り専用シーンデータ (Uniform Buffer) 【追加】
layout(std140, binding = 1) uniform SceneData {
    vec4 resolution; // x=width, y=height, z=unused, w=unused
    vec4 params;     // x=time, y=frame_count, z=unused, w=unused
    vec4 cameraPos;  // カメラ位置
} scene;

void main() {
    uint width = uint(scene.resolution.x);
    uint height = uint(scene.resolution.y);
    
    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;

    if (x >= width || y >= height) return;

    uint index = y * width + x;

    // 時間(Time)を使って色を動かす
    float time = scene.params.x;
    
    float u = float(x) / float(width);
    float v = float(y) / float(height);

    // 時間経過で色が波打つエフェクト
    float r = 0.5 + 0.5 * sin(time + u * 6.28);
    float g = v;
    float b = 0.5 + 0.5 * cos(time + v * 6.28);

    image.pixels[index].r = r;
    image.pixels[index].g = g;
    image.pixels[index].b = b;
    image.pixels[index].a = 1.0;
}