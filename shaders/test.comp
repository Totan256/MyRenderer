#version 450

// ワークグループのサイズ（1スレッドグループあたり256スレッド）
layout (local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

// CPUからデータを受け取るバッファ（Binding = 0）
layout(std430, binding = 0) buffer StorageBuffer {
    float data[];
} bufferOut;

void main() {
    // グローバルなスレッドIDを取得
    uint gID = gl_GlobalInvocationID.x;

    // 配列のインデックスとして使用し、値を書き込む
    // 例: インデックス * 10.0 を書き込む
    bufferOut.data[gID] = float(gID) * 10.0;
}